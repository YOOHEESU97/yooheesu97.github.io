---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getCategoryLabel } from '../utils/categories';
import { withBase } from '../utils/withBase';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, category, tags } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main class="is-narrow">
			<article class="post">
				<header class="post-header">
					<h1>{title}</h1>
					<p class="post-meta">
						<FormattedDate date={pubDate} />에 작성
						{
							category && (
								<a class="category-badge" href={withBase(`category/${category}/`)}>
									{getCategoryLabel(category)}
								</a>
							)
						}
						{
							tags && tags.length > 0 && (
								<span class="tags">
									{tags.map((tag) => (
										<span class="tag">{tag}</span>
									))}
								</span>
							)
						}
					</p>
					{
						updatedDate && (
							<p class="updated">
								수정: <FormattedDate date={updatedDate} />
							</p>
						)
					}
				</header>
				<div class="content">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-header {
		text-align: center;
		margin-bottom: 2.5rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--border);
	}

	.post-header h1 {
		margin-bottom: 1rem;
		font-size: 2.5rem;
		line-height: 1.2;
	}

	.post-meta {
		margin: 0;
		font-size: 0.9rem;
		color: var(--text-muted);
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.tags {
		display: inline-flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}

	.updated {
		margin: 0.65rem 0 0;
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.content :global(a) {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.content :global(a:hover) {
		text-decoration: none;
	}

	.content :global(p:last-child) {
		margin-bottom: 0;
	}

	@media (max-width: 768px) {
		.post-header h1 {
			font-size: 1.85rem;
		}
	}
</style>
