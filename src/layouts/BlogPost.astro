---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { SITE_TITLE } from '../consts';
import { getCategoryLabel } from '../utils/categories';
import { withBase } from '../utils/withBase';

type PostData = CollectionEntry<'blog'>['data'];

type Heading = {
	depth: number;
	slug: string;
	text: string;
};

type Props = PostData & {
	readingTimeMinutes?: number;
	headings?: Heading[];
	relatedPosts?: CollectionEntry<'blog'>[];
	pageType?: 'website' | 'article';
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	category,
	tags,
	readingTimeMinutes,
	headings = [],
	relatedPosts = [],
	pageType = 'article',
} = Astro.props;

const pageTitle = `${title} | ${SITE_TITLE}`;
const isArticle = pageType === 'article';
---

<html lang="ko">
	<head>
		<BaseHead
			title={pageTitle}
			description={description}
			ogType={isArticle ? 'article' : 'website'}
		/>
	</head>
	<body>
		<Header />
		<main class="is-narrow">
			<article class="post">
				<header class="post-header">
					<h1>{title}</h1>
					<p class="post-meta">
						<FormattedDate date={pubDate} />에 작성
						{readingTimeMinutes && <span class="reading-time">· 약 {readingTimeMinutes}분</span>}
						{
							category && (
								<a class="category-badge" href={withBase(`category/${category}/`)}>
									{getCategoryLabel(category)}
								</a>
							)
						}
						{
							tags && tags.length > 0 && (
								<span class="tags">
									{tags.map((tag) => (
										<span class="tag">{tag}</span>
									))}
								</span>
							)
						}
					</p>
					{
						updatedDate && (
							<p class="updated">
								최종 수정: <FormattedDate date={updatedDate} />
							</p>
						)
					}
				</header>
				{isArticle && headings.length > 0 && <TableOfContents headings={headings} />}
				<div class="content prose">
					<slot />
				</div>
				{isArticle && relatedPosts.length > 0 && <RelatedPosts posts={relatedPosts} />}
			</article>
		</main>
		<Footer />
		<script>
			document.querySelectorAll('[data-copy]').forEach((button) => {
				button.addEventListener('click', async () => {
					const block = button.closest('.code-block');
					const code = block?.querySelector('code');
					const text = code?.textContent ?? '';
					if (!text) return;

					try {
						await navigator.clipboard.writeText(text);
						button.textContent = 'Copied!';
						setTimeout(() => {
							button.textContent = 'Copy';
						}, 1500);
					} catch {
						button.textContent = 'Failed';
					}
				});
			});
		</script>
	</body>
</html>

<style>
	.post-header {
		text-align: center;
		margin-bottom: 2.5rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--border);
	}

	.post-header h1 {
		margin-bottom: 1rem;
		font-size: 2.5rem;
		line-height: 1.2;
	}

	.post-meta {
		margin: 0;
		font-size: 0.9rem;
		color: var(--text-muted);
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.reading-time {
		white-space: nowrap;
	}

	.tags {
		display: inline-flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}

	.updated {
		margin: 0.65rem 0 0;
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.content :global(a) {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.content :global(a:hover) {
		text-decoration: none;
	}

	.content :global(p:last-child) {
		margin-bottom: 0;
	}

	.content :global(.table-scroll) {
		max-width: 100%;
	}

	.content :global(.code-block) {
		position: relative;
		margin: 1.25rem 0;
	}

	.content :global(.code-block pre) {
		margin: 0;
	}

	.content :global(.code-copy-btn) {
		position: absolute;
		top: 0.55rem;
		right: 0.55rem;
		padding: 0.25rem 0.55rem;
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--text-muted);
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 6px;
		cursor: pointer;
		z-index: 1;
	}

	.content :global(.code-copy-btn:hover) {
		color: var(--accent);
		border-color: var(--accent);
	}

	@media (max-width: 768px) {
		.post-header {
			margin-bottom: 1.75rem;
			padding-bottom: 1.5rem;
		}

		.post-header h1 {
			font-size: 1.55rem;
			line-height: 1.35;
			word-break: keep-all;
			overflow-wrap: break-word;
		}

		.post-meta {
			font-size: 0.825rem;
			gap: 0.4rem;
		}
	}

	@media (max-width: 480px) {
		.post-header h1 {
			font-size: 1.4rem;
		}
	}
</style>
