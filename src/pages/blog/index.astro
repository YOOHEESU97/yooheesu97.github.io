---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getReadingTimeMinutes } from '../../utils/readingTime';
import { withBase } from '../../utils/withBase';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead
			title={`Notes | ${SITE_TITLE}`}
			description="30+ developer troubleshooting notes — Java, Spring, React, TypeScript, Python, Node.js, and more."
		/>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Notes</h1>
				<span class="article-count">{posts.length} Articles</span>
			</div>
			<p class="intro">개발하면서 정리한 코딩 노트 모음입니다.</p>
			<ul class="post-grid">
				{
					posts.map((post) => (
						<li>
							<PostCard
								href={withBase(`blog/${post.id}/`)}
								title={post.data.title}
								description={post.data.description}
								pubDate={post.data.pubDate}
								updatedDate={post.data.updatedDate}
								category={post.data.category}
								tags={post.data.tags}
								readingTimeMinutes={getReadingTimeMinutes(post.body ?? '')}
							/>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		margin: -1rem 0 2rem;
		color: var(--text-muted);
		font-size: 1.05rem;
	}
</style>
