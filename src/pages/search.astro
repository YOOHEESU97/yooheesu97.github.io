---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { withBase } from '../utils/withBase';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead
			title={`Search | ${SITE_TITLE}`}
			description="Search coding notes and troubleshooting guides."
		/>
		<link href={withBase('/pagefind/pagefind-ui.css')} rel="stylesheet" />
	</head>
	<body>
		<Header />
		<main class="is-narrow">
			<div class="page-header">
				<h1>Search</h1>
			</div>
			<p class="intro">글 제목·본문에서 키워드를 검색합니다.</p>
			<div id="search"></div>
		</main>
		<Footer />
		<script is:inline src={withBase('/pagefind/pagefind-ui.js')}></script>
		<script is:inline define:vars={{ baseUrl: import.meta.env.BASE_URL }}>
			function initPagefind() {
				if (typeof PagefindUI === 'undefined') return;
				new PagefindUI({
					element: '#search',
					baseUrl,
					showImages: false,
				});
			}

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initPagefind);
			} else {
				initPagefind();
			}
		</script>
	</body>
</html>

<style>
	.intro {
		margin: -1rem 0 1.5rem;
		color: var(--text-muted);
	}

	#search {
		--pagefind-ui-scale: 0.95;
		--pagefind-ui-primary: var(--accent);
		--pagefind-ui-text: var(--text);
		--pagefind-ui-background: var(--bg-card);
		--pagefind-ui-border: var(--border);
		--pagefind-ui-tag: var(--bg-elevated);
	}
</style>
