---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getCategoriesWithPosts } from '../../utils/categoryPosts';
import { withBase } from '../../utils/withBase';

const posts = await getCollection('blog');
const activeCategories = getCategoriesWithPosts(posts);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead
			title={`Categories | ${SITE_TITLE}`}
			description="Browse coding notes by Java, Spring, React, TypeScript, Python, Node.js, and more."
		/>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Categories</h1>
			</div>
			<p class="intro">Browse notes by technology.</p>
			<ul class="category-grid">
				{
					activeCategories.map((category) => (
						<li>
							<a class="category-card" href={withBase(`category/${category.slug}/`)}>
								<h2>{category.label}</h2>
								<p>{category.description}</p>
								<span class="category-count">{category.count} posts</span>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		margin: -1rem 0 2rem;
		color: var(--text-muted);
		font-size: 1.05rem;
	}

	.category-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.25rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.category-card {
		display: flex;
		flex-direction: column;
		height: 100%;
		padding: 1.5rem 1.6rem 1.35rem;
		background: var(--bg-card);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		color: inherit;
		transition:
			box-shadow 0.2s ease,
			transform 0.2s ease;
	}

	.category-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
		color: inherit;
	}

	.category-card h2 {
		margin: 0 0 0.65rem;
		font-size: 1.35rem;
	}

	.category-card p {
		margin: 0 0 1rem;
		flex: 1;
		font-size: 0.95rem;
		line-height: 1.65;
		color: var(--text-muted);
	}

	.category-count {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--accent);
	}

	@media (max-width: 900px) {
		.category-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
