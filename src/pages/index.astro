---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCategoriesWithPosts } from '../utils/categoryPosts';
import { getReadingTimeMinutes } from '../utils/readingTime';
import { withBase } from '../utils/withBase';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const allPosts = await getCollection('blog');
const activeCategories = getCategoriesWithPosts(allPosts);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead
			title={`${SITE_TITLE} — 개발 코딩 노트`}
			description={SITE_DESCRIPTION}
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>{SITE_TITLE}</h1>
				<p>{SITE_DESCRIPTION}</p>
			</section>

			<section>
				<div class="page-header">
					<h2 class="section-title">최근 노트</h2>
					<a class="view-all" href={withBase('blog/')}>모든 노트 보기 →</a>
				</div>
				<ul class="post-grid">
					{
						posts.map((post) => (
							<li>
								<PostCard
									href={withBase(`blog/${post.id}/`)}
									title={post.data.title}
									description={post.data.description}
									pubDate={post.data.pubDate}
									updatedDate={post.data.updatedDate}
									category={post.data.category}
									tags={post.data.tags}
									readingTimeMinutes={getReadingTimeMinutes(post.body ?? '')}
								/>
							</li>
						))
					}
				</ul>
			</section>

			<section class="categories-section">
				<div class="page-header">
					<h2 class="section-title">Categories</h2>
					<a class="view-all" href={withBase('category/')}>View all →</a>
				</div>
				<ul class="category-grid">
					{
						activeCategories.map((category) => (
							<li>
								<a class="category-card" href={withBase(`category/${category.slug}/`)}>
									<h3>{category.label}</h3>
									<p>{category.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		margin-bottom: 3rem;
		padding: 0.5rem 0 0.25rem;
	}

	.hero h1 {
		margin-bottom: 0.65rem;
		font-size: 2.75rem;
	}

	.hero p {
		margin: 0 auto;
		max-width: 32rem;
		color: var(--text-muted);
		font-size: 1.1rem;
		line-height: 1.65;
	}

	.section-title {
		margin: 0;
		font-size: 1.75rem;
	}

	.view-all {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--text-muted);
		white-space: nowrap;
	}

	.view-all:hover {
		color: var(--accent);
		text-decoration: none;
	}

	@media (max-width: 768px) {
		.hero h1 {
			font-size: 2rem;
		}
	}

	.categories-section {
		margin-top: 3.5rem;
	}

	.category-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.25rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.category-card {
		display: block;
		height: 100%;
		padding: 1.35rem 1.4rem;
		background: var(--bg-card);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		color: inherit;
		transition:
			box-shadow 0.2s ease,
			transform 0.2s ease;
	}

	.category-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
		color: inherit;
	}

	.category-card h3 {
		margin: 0 0 0.5rem;
		font-size: 1.15rem;
	}

	.category-card p {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.6;
		color: var(--text-muted);
	}

	@media (max-width: 900px) {
		.category-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
