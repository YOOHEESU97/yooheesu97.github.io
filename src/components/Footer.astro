---
import { getCollection } from 'astro:content';
import { GITHUB_URL } from '../consts';
import { getCategoriesWithPosts } from '../utils/categoryPosts';
import { withBase } from '../utils/withBase';

const year = new Date().getFullYear();
const posts = await getCollection('blog');
const activeCategories = getCategoriesWithPosts(posts);
---

<footer>
	<div class="footer-inner">
		<p class="footer-categories">
			{
				activeCategories.map((category, index) => (
					<>
						{index > 0 && <span aria-hidden="true">·</span>}
						<a href={withBase(`category/${category.slug}/`)}>{category.label}</a>
					</>
				))
			}
		</p>
		<p class="footer-links">
			<a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
			<span aria-hidden="true">·</span>
			<a href={withBase('rss.xml')}>RSS</a>
			<span aria-hidden="true">·</span>
			<a href={withBase('privacy/')}>개인정보처리방침</a>
		</p>
		<p class="copyright">&copy; {year} Coding Notes</p>
	</div>
</footer>

<style>
	footer {
		margin-top: 1rem;
		padding: 2.5rem 0 3.5rem;
	}

	.footer-inner {
		width: var(--max-width);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		text-align: center;
	}

	footer p {
		margin: 0;
		font-size: 0.875rem;
		color: var(--text-muted);
	}

	.footer-categories,
	.footer-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.footer-links {
		margin-top: 0.6rem;
	}

	footer a {
		color: var(--text-muted);
		font-weight: 500;
	}

	footer a:hover {
		color: var(--accent);
	}

	.copyright {
		margin-top: 0.6rem !important;
		font-size: 0.8rem !important;
	}
</style>
