---
import { SITE_TITLE } from '../consts';
import { withBase } from '../utils/withBase';
import CloudDivider from './CloudDivider.astro';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="site-header">
	<nav>
		<a class="site-title" href={withBase()}>{SITE_TITLE}</a>
		<div class="header-right">
			<div class="nav-links">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/blog">Notes</HeaderLink>
				<HeaderLink href="/category">Categories</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</div>
			<ThemeToggle />
		</div>
	</nav>
	<CloudDivider />
</header>

<style>
	.site-header {
		background: linear-gradient(180deg, var(--bg-header) 0%, var(--bg-header-end) 100%);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: var(--max-width);
		max-width: calc(100% - 2.5rem);
		margin: 0 auto;
		padding: 1.15rem 0 0.5rem;
	}

	.site-title {
		font-size: 1.05rem;
		font-weight: 700;
		color: var(--accent);
		text-decoration: none;
		letter-spacing: -0.02em;
	}

	.site-title:hover {
		color: var(--accent-hover);
	}

	.header-right {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.nav-links {
		display: flex;
		gap: 0.15rem;
	}

	.nav-links :global(a) {
		padding: 0.4rem 0.75rem;
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--text-muted);
		border-radius: 8px;
		transition:
			color 0.15s ease,
			background 0.15s ease;
	}

	.nav-links :global(a:hover) {
		color: var(--text);
		background: var(--nav-hover-bg);
		text-decoration: none;
	}

	.nav-links :global(a.active) {
		color: var(--text);
		background: var(--nav-active-bg);
		font-weight: 600;
		text-decoration: none;
	}

	@media (max-width: 640px) {
		nav {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.85rem;
		}

		.header-right {
			width: 100%;
			justify-content: space-between;
		}
	}
</style>
