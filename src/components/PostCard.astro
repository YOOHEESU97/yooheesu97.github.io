---
import FormattedDate from './FormattedDate.astro';
import { getCategoryLabel, type CategorySlug } from '../utils/categories';

interface Props {
	href: string;
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	category?: CategorySlug;
	tags?: string[];
	readingTimeMinutes?: number;
}

const { href, title, description, pubDate, updatedDate, category, tags, readingTimeMinutes } =
	Astro.props;
---

<article class="post-card">
	<a href={href} class="post-card-link">
		<h2 class="post-card-title">{title}</h2>
		<p class="post-card-meta">
			<FormattedDate date={pubDate} />
			{readingTimeMinutes && <span>· {readingTimeMinutes} min</span>}
			{updatedDate && <span class="updated-badge">Updated</span>}
			{
				category && (
					<span class="category-badge">{getCategoryLabel(category)}</span>
				)
			}
			{tags?.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
		</p>
		<p class="post-card-excerpt">{description}</p>
		<span class="read-more">더 읽기 →</span>
	</a>
</article>

<style>
	.updated-badge {
		font-size: 0.68rem;
		font-weight: 700;
		padding: 0.1rem 0.45rem;
		border-radius: 999px;
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 12%, transparent);
	}
</style>
