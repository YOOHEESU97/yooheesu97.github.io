---
import type { HTMLAttributes } from 'astro/types';
import { withBase } from '../utils/withBase';

type Props = HTMLAttributes<'a'>;

const { href = '/', class: className, ...props } = Astro.props;
const resolvedHref = typeof href === 'string' ? withBase(href) : href;

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '/');
const normalizedPath = pathname.replace(/\/index\.html$/, '/').replace(/\/$/, '') || '/';
const normalizedHref = (typeof href === 'string' ? href : '/').replace(/\/$/, '') || '/';
const isActive =
	normalizedHref === normalizedPath ||
	normalizedHref === `/${normalizedPath.split('/').filter(Boolean)[0] || ''}`;
---

<a href={resolvedHref} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>

<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
</style>
